{
  "manifest_version": 3,
  "name": "Domain Insight",
  "description": "Show domain, DNS, RDAP, and IP details for the current tab.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Domain Insight"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs", "storage", "contextMenus", "scripting"],
  "host_permissions": [
    "https://cloudflare-dns.com/*",
    "https://dns.google/*",
    "https://rdap.org/*",
    "https://ipinfo.io/*"
  ]
}
